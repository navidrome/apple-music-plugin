{
  "$schema": "https://raw.githubusercontent.com/navidrome/navidrome/refs/heads/master/plugins/manifest-schema.json",
  "name": "Apple Music Metadata Agent",
  "author": "Navidrome Team",
  "version": "0.1.1",
  "description": "Fetches artist metadata from Apple Music using free iTunes/Apple Music endpoints",
  "website": "https://github.com/navidrome/apple-music-plugin",
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "cache_ttl_days": {
          "type": "integer",
          "title": "Cache TTL (days)",
          "description": "How long to cache scraped metadata before re-fetching",
          "default": 7
        },
        "countries": {
          "type": "string",
          "title": "Countries",
          "description": "Comma-separated list of two-letter ISO country codes for Apple Music storefronts, tried in order until content is found. Controls the language of artist biographies (e.g., 'br' returns Portuguese, 'de' returns German).",
          "default": "us"
        },
        "enable_artist_url": {
          "type": "boolean",
          "title": "Artist URL",
          "default": true
        },
        "enable_artist_biography": {
          "type": "boolean",
          "title": "Artist Biography",
          "default": true
        },
        "enable_artist_images": {
          "type": "boolean",
          "title": "Artist Images",
          "default": true
        },
        "enable_similar_artists": {
          "type": "boolean",
          "title": "Similar Artists",
          "default": true
        },
        "enable_top_songs": {
          "type": "boolean",
          "title": "Top Songs",
          "default": true
        },
        "enable_album_images": {
          "type": "boolean",
          "title": "Album Images",
          "default": false
        }
      }
    },
    "uiSchema": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "HorizontalLayout",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/countries",
              "options": {
                "size": 9
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/cache_ttl_days",
              "options": {
                "size": 3
              }
            }
          ]
        },
        {
          "type": "Label",
          "text": "Capabilities"
        },
        {
          "type": "HorizontalLayout",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/enable_artist_url"
            },
            {
              "type": "Control",
              "scope": "#/properties/enable_artist_biography"
            },
            {
              "type": "Control",
              "scope": "#/properties/enable_artist_images"
            }
          ]
        },
        {
          "type": "HorizontalLayout",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/enable_similar_artists"
            },
            {
              "type": "Control",
              "scope": "#/properties/enable_top_songs"
            },
            {
              "type": "Control",
              "scope": "#/properties/enable_album_images"
            }
          ]
        }
      ]
    }
  },
  "permissions": {
    "http": {
      "reason": "Fetch artist metadata from iTunes API and Apple Music web pages",
      "requiredHosts": [
        "itunes.apple.com",
        "music.apple.com"
      ]
    },
    "kvstore": {
      "reason": "Cache artist ID mappings and scraped metadata to reduce API calls",
      "maxSize": "10MB"
    }
  }
}
